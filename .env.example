# Supabase (Auth + PostgreSQL — kein Storage nötig)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App — URL inkl. basePath (bellabianca.at/daily)
NEXT_PUBLIC_APP_URL=https://bellabianca.at/daily
# Nur der Pfad-Prefix für client-seitige fetch-Aufrufe (leer lassen auf localhost)
NEXT_PUBLIC_BASE_PATH=/daily
ADMIN_EMAIL=admin@your-domain.com

# Cron-Absicherung (zufälliger langer String)
CRON_SECRET=your-secret-here

# Optional: Slack/Discord Webhook für Cron-Fehler-Benachrichtigungen
ADMIN_WEBHOOK_URL=https://hooks.slack.com/services/...
